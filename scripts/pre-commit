#!/bin/bash

echo "🔍 Running pre-commit checks..."
echo ""

# Check if golangci-lint is installed
if ! command -v golangci-lint &> /dev/null; then
    echo "❌ golangci-lint 未安装！"
    echo ""
    echo "💡 请先安装 golangci-lint："
    echo "   macOS: brew install golangci-lint"
    echo "   或运行: make install-linter"
    echo ""
    echo "⚠️  提交被阻止，请安装工具后再提交。"
    echo ""
    exit 1
fi

# Run golangci-lint
echo "Running golangci-lint..."
make lint
LINT_EXIT_CODE=$?

if [ $LINT_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "⚠️  Lint 检查失败，尝试自动修复..."
    echo ""
    
    # Auto-fix lint issues
    make lint-fix
    
    echo ""
    echo "🔄 自动修复完成，重新检查..."
    echo ""
    
    # Re-run lint check after fix
    make lint
    RELINT_EXIT_CODE=$?
    
    if [ $RELINT_EXIT_CODE -eq 0 ]; then
        echo ""
        echo "✅ Lint 检查通过（已自动修复）"
        echo ""
        echo "💡 提示：修复的文件已暂存，请检查修改是否正确。"
        echo "   使用 'git diff --cached' 查看修改"
        exit 0
    else
        echo ""
        echo "❌ Lint 检查仍然失败，请手动修复后再提交。"
        echo ""
        echo "💡 提示："
        echo "   - 部分问题无法自动修复，需要手动处理"
        echo "   - 运行 'make lint' 查看所有问题"
        echo ""
        exit 1
    fi
fi

echo ""
echo "✅ Lint 检查通过"
exit 0
