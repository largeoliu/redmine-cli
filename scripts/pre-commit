#!/bin/bash

echo "Running pre-commit checks..."
echo ""

FAILED=0

if ! command -v golangci-lint &> /dev/null; then
    echo "golangci-lint is not installed!"
    echo ""
    echo "Please install golangci-lint:"
    echo "   macOS: brew install golangci-lint"
    echo "   Or run: make install-linter"
    echo ""
    echo "Commit blocked - please install the tool before committing."
    echo ""
    exit 1
fi

echo "=== Checking go mod tidy ==="
go mod tidy
if ! git diff --exit-code go.mod go.sum; then
    echo "go.mod or go.sum changed after 'go mod tidy'"
    git add go.mod go.sum
    FAILED=1
fi
echo ""

echo "=== Checking go mod verify ==="
if ! go mod verify; then
    echo "go mod verify failed"
    FAILED=1
fi
echo ""

echo "=== Checking gofmt ==="
FMT_FILES=$(gofmt -s -l .)
if [ -n "$FMT_FILES" ]; then
    echo "The following files need formatting:"
    echo "$FMT_FILES"
    gofmt -s -w $FMT_FILES
    git add $FMT_FILES
    FAILED=1
fi
echo ""

echo "=== Checking goimports ==="
if command -v goimports &> /dev/null; then
    IMPORT_FILES=$(goimports -l .)
    if [ -n "$IMPORT_FILES" ]; then
        echo "The following files need import formatting:"
        echo "$IMPORT_FILES"
        goimports -w $IMPORT_FILES
        git add $IMPORT_FILES
        FAILED=1
    fi
else
    echo "goimports not installed, skipping import check"
fi
echo ""

echo "=== Running golangci-lint ==="
make lint
LINT_EXIT_CODE=$?

if [ $LINT_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "Lint check failed, attempting auto-fix..."
    echo ""

    make lint-fix

    echo ""
    echo "Auto-fix complete, re-checking..."
    echo ""

    make lint
    RELINT_EXIT_CODE=$?

    if [ $RELINT_EXIT_CODE -eq 0 ]; then
        echo ""
        echo "Lint check passed (auto-fixed)"
        echo ""
        echo "Note: Fixed files are staged, please verify the changes."
        echo "  Use 'git diff --cached' to review"
    else
        echo ""
        echo "Lint check still failing, please fix manually."
        echo ""
        echo "Tips:"
        echo "  - Some issues cannot be auto-fixed"
        echo "  - Run 'make lint' to see all issues"
        echo ""
        FAILED=1
    fi
fi
echo ""

if [ $FAILED -ne 0 ]; then
    echo "Pre-commit checks failed. Please review and re-commit."
    exit 1
fi

echo "All pre-commit checks passed"
exit 0
