# Integration Test Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Required: Your Redmine instance URL
REDMINE_URL=https://your-redmine-instance.com

# Required: Your Redmine API key
# You can find this in your Redmine profile page under "API access key"
REDMINE_API_KEY=your-api-key-here

# Recommended: Project ID for isolated testing
# All test issues will be created in this project
# This prevents tests from affecting other projects
REDMINE_PROJECT_ID=1

# Optional: Custom limit for tests
REDMINE_TEST_LIMIT=25
