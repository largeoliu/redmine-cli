{
  "name": "redminectl",
  "version": "0.1.0",
  "description": "AI Agent friendly Redmine CLI tool. This npm package is named 'redminectl' because 'redmine' was already taken on npm. The installed binary is still 'redmine'.",
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/download.js",
    "prepare": "if [ -x node_modules/.bin/husky ]; then husky; fi",
    "lint:commit": "commitlint --from=HEAD~1 --to=HEAD"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/largeoliu/redmine-cli.git"
  },
  "keywords": [
    "redmine",
    "cli",
    "issue-tracker",
    "project-management",
    "ai-agent"
  ],
  "author": "largeoliu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/largeoliu/redmine-cli/issues"
  },
  "homepage": "https://github.com/largeoliu/redmine-cli#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tar": "^7.5.13",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "husky": "^9.1.7"
  },
  "files": [
    "scripts/download.js"
  ]
}
